---
import Layout from '../layouts/Layout.astro';
---

<Layout title="How We Work - Skief Labs" description="Structured work. No chaos. No dependency. Learn how Skief Labs approaches every engagement with clarity and restraint.">
  <!-- HERO -->
  <section class="bg-linen pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <h1 class="page-hero-title heading-serif text-4xl md:text-5xl lg:text-[3.8rem] mb-6 leading-[1.1] uppercase" style="color: #001D52;">
            Clear process.<br />No chaos.<br />No lock-in.
          </h1>
          <div class="page-hero-body text-black text-sm md:text-base leading-relaxed max-w-xl">
            <p>
              Most automation projects fail not because the technology is<br />
              wrong, but because the process around it is absent. We build<br />
              systems with structure and documentation — so you're never<br />
              dependent on us to run them.
            </p>
          </div>
        </div>
        <!-- Right: Flowchart graphic (with neon offset shadow) -->
        <div class="page-hero-image relative flex justify-center">
          <div class="w-full max-w-[420px] rounded-[10px] shadow-[8px_8px_0px_0px_#CFFF15] flex items-center justify-center p-8 md:p-10" style="background-color: #D9D9D9; aspect-ratio: 16/10;">
            <svg viewBox="0 0 400 160" class="w-full h-auto" fill="none" xmlns="http://www.w3.org/2000/svg">

              <!-- Connector dashed lines -->
              <line x1="79"  y1="75" x2="150" y2="75" stroke="#0A60FF" stroke-width="1.5" stroke-dasharray="4,4" stroke-opacity="0.7"/>
              <line x1="180" y1="75" x2="246" y2="75" stroke="#0A60FF" stroke-width="1.5" stroke-dasharray="4,4" stroke-opacity="0.7"/>
              <line x1="284" y1="75" x2="341" y2="75" stroke="#0A60FF" stroke-width="1.5" stroke-dasharray="4,4" stroke-opacity="0.7"/>

              <!-- TRAVELER — drawn first so shapes render on top -->
              <g id="hw-traveler-group">
                <circle class="hw-radar" r="11" fill="none" stroke="#001D52" stroke-width="1.2"/>
                <circle r="8"   fill="none" stroke="#001D52" stroke-width="2"/>
                <circle r="3.5" fill="#001D52"/>
              </g>

              <!-- SHAPES — drawn on top of traveler -->
              <polygon points="48,60 48,90 78,75" fill="#0A60FF"/>
              <rect    x="151" y="61" width="28" height="28" fill="#0A60FF"/>
              <polygon points="265,59 283,75 265,91 247,75" fill="#0A60FF"/>
              <polygon points="355,60 368,68 368,83 355,90 342,83 342,68" fill="#0A60FF"/>

              <!-- LABELS — only these glow when dot passes -->
              <text id="hw-lbl-i" x="63"  y="114" fill="#0A60FF" font-size="13" font-family="Nunito, sans-serif" font-weight="600" text-anchor="middle">Input</text>
              <text id="hw-lbl-p" x="165" y="114" fill="#0A60FF" font-size="13" font-family="Nunito, sans-serif" font-weight="600" text-anchor="middle">Process</text>
              <text id="hw-lbl-d" x="265" y="114" fill="#0A60FF" font-size="13" font-family="Nunito, sans-serif" font-weight="600" text-anchor="middle">Decision</text>
              <text id="hw-lbl-o" x="355" y="114" fill="#0A60FF" font-size="13" font-family="Nunito, sans-serif" font-weight="600" text-anchor="middle">Output</text>
            </svg>
          </div>

          <style>
            /*
              Dot travels x=78→355 continuously with no stops.
              7s cycle: 0-4% fade in, 4-88% smooth linear travel, 88-93% fade out, 93-100% invisible snap back.
              Label glow fires when dot is at each node x position.
                Input  (x≈63):  dot starts here → glow 3–9%
                Process(x=165): arrives at ~30%  → glow 27–35%
                Decision(x=265):arrives at ~61%  → glow 58–66%
                Output (x=355): arrives at ~88%  → glow 85–93%
            */
            /*
              Dot enters from the very left edge (x=0), travels through Input icon,
              continues to Process → Decision → Output. Label glows as dot crosses each node.
                Input  (x=63):  dot hits at ~18% → glow 15–23%
                Process(x=165): dot hits at ~43% → glow 40–48%
                Decision(x=265):dot hits at ~66% → glow 63–71%
                Output (x=355): dot hits at ~88% → glow 85–93%
            */
            @keyframes hw-dot-journey {
              0%   { transform: translate(63px, 75px);  opacity: 0; }   /* at Input, hidden */
              3%   { transform: translate(63px, 75px);  opacity: 1; }   /* appear at Input */
              88%  { transform: translate(355px, 75px); opacity: 1; }   /* at Output */
              93%  { transform: translate(355px, 75px); opacity: 0; }   /* fade out */
              100% { transform: translate(63px, 75px);  opacity: 0; }   /* snap back */
            }
            #hw-traveler-group { animation: hw-dot-journey 7s linear 1.3s infinite backwards; }

            /* Continuous radar ring on the dot */
            @keyframes hw-radar-spin {
              0%   { transform: scale(1);   opacity: 0.6; }
              100% { transform: scale(2.0); opacity: 0;   }
            }
            .hw-radar {
              transform-box: fill-box;
              transform-origin: center;
              animation: hw-radar-spin 1.4s ease-out 1.3s infinite backwards;
            }

            /* Label glows only — timed to when dot crosses each node
               Dot travels x=63→355 over 3%–88%.
               Input  (x=63):  dot appears here    → glow 1–9%
               Process(x=165): 3% + 35%*85% ≈ 33% → glow 30–38%
               Decision(x=265):3% + 69%*85% ≈ 62% → glow 59–67%
               Output (x=355): arrives at 88%      → glow 85–93%
            */
            @keyframes hw-li {
              0%       { fill: #0A60FF; }
              3%       { fill: #93d0ff; }
              10%      { fill: #0A60FF; }
              100%     { fill: #0A60FF; }
            }
            @keyframes hw-lp {
              0%, 29%  { fill: #0A60FF; }
              33%      { fill: #93d0ff; }
              40%      { fill: #0A60FF; }
              100%     { fill: #0A60FF; }
            }
            @keyframes hw-ld {
              0%, 58%  { fill: #0A60FF; }
              62%      { fill: #93d0ff; }
              69%      { fill: #0A60FF; }
              100%     { fill: #0A60FF; }
            }
            @keyframes hw-lo {
              0%, 84%  { fill: #0A60FF; }
              88%      { fill: #93d0ff; }
              95%      { fill: #0A60FF; }
              100%     { fill: #0A60FF; }
            }
            #hw-lbl-i { animation: hw-li 7s linear 1.3s infinite backwards; }
            #hw-lbl-p { animation: hw-lp 7s linear 1.3s infinite backwards; }
            #hw-lbl-d { animation: hw-ld 7s linear 1.3s infinite backwards; }
            #hw-lbl-o { animation: hw-lo 7s linear 1.3s infinite backwards; }
          </style>
        </div>
      </div>
    </div>
  </section>

