</Layout>

<style>
  .tree-vline, .tree-hline, .tree-card {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tree-vline.tree-visible {
    transform: translateX(-50%) scaleY(1) !important;
  }
  .tree-hline.tree-visible {
    transform: translateY(-50%) scaleX(1) !important;
  }
  .tree-card.tree-visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
</style>

<script>
  // Scroll-driven tree animation — sequenced one-at-a-time so lines never skip
  const section = document.getElementById('principles-section');
  if (section) {
    const steps = [
      'vline1', 'hline1', 'card1',
      'vline2', 'hline2', 'card2',
      'vline3', 'hline3', 'card3',
      'vline4', 'hline4', 'card4',
      'vline5', 'hline5', 'card5',
      'vline6', 'summary'
    ];

    const elements = steps.map(s => section.querySelector(`[data-tree="${s}"]`)).filter(Boolean) as HTMLElement[];
    let maxRevealed = -1;
    let revealTimer: ReturnType<typeof setTimeout> | null = null;

    function revealSequence() {
      const nextIndex = maxRevealed + 1;
      if (nextIndex >= elements.length) return;

      const rect = section!.getBoundingClientRect();
      const viewH = window.innerHeight;

      // Guard: don't start drawing until the section has scrolled well into view.
      // This prevents tree lines from firing on initial page load before the user scrolls.
      if (rect.top > viewH * 0.45) {
        revealTimer = null;
        return;
      }

      const scrolled = viewH - rect.top;
      const totalRange = rect.height + viewH * 0.4;
      const progress = Math.max(0, Math.min(1, scrolled / totalRange));
      const stepSize = 1 / elements.length;
      const threshold = nextIndex * stepSize;

      if (progress > threshold) {
        maxRevealed = nextIndex;
        elements[nextIndex].classList.add('tree-visible');
        // Each step waits 160ms before revealing the next — smooth cascade even on fast scroll
        revealTimer = setTimeout(revealSequence, 160);
      } else {
        revealTimer = null;
      }
    }

    function updateTree() {
      if (revealTimer) return; // Let the current cascade finish uninterrupted
      revealSequence();
    }

    window.addEventListener('scroll', updateTree, { passive: true });
    updateTree();
  }
</script>
