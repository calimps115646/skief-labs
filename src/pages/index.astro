<script>
  // Scale hero cards to fit available space
  function scaleHeroCards() {
    const wrapper = document.getElementById('hero-cards');
    const inner = wrapper?.querySelector('.hero-cards-inner') as HTMLElement | null;
    if (!wrapper || !inner) return;

    const nativeWidth = 550;
    const nativeHeight = 490;
    const isMobile = window.innerWidth < 900; // stacked (1-column) layout

    // Get available width — wrapper has min-width:0 + overflow:hidden
    // so it respects the grid column width
    const availableWidth = isMobile
      ? (window.innerWidth - 64)  // viewport minus px-8 padding (32px each side)
      : wrapper.clientWidth;

    // Scale by width
    const scaleByWidth = Math.min(availableWidth / nativeWidth, 1);

    // On mobile, also constrain by height so cards stay compact
    let scale = scaleByWidth;
    if (isMobile) {
      const maxCardHeight = Math.min(280, window.innerHeight * 0.35);
      const scaleByHeight = maxCardHeight / nativeHeight;
      scale = Math.min(scaleByWidth, scaleByHeight);
    }

    // Apply scale
    if (scale < 1) {
      inner.style.transform = `scale(${scale})`;
      inner.style.height = `${nativeHeight}px`;
      wrapper.style.height = `${nativeHeight * scale}px`;
    } else {
      inner.style.transform = 'scale(1)';
      wrapper.style.height = `${nativeHeight}px`;
    }

    // Center cards on mobile
    if (isMobile) {
      const scaledWidth = nativeWidth * scale;
      const leftOffset = Math.max(0, (availableWidth - scaledWidth) / 2);
      inner.style.marginLeft = `${leftOffset}px`;
    } else {
      inner.style.marginLeft = '0';
    }
  }

  // Hero entrance animation — letter-by-letter title, then fade in body + cards together
  function splitTextToChars(el: HTMLElement) {
    const text = el.textContent || '';
    el.innerHTML = '';
    text.split('').forEach((char, i) => {
      const span = document.createElement('span');
      span.className = char === ' ' ? 'hero-char hero-char-space' : 'hero-char';
      span.textContent = char === ' ' ? '\u00A0' : char;
      // Stagger: 30ms per character, total ~0.8s for ~26 chars
      span.style.animationDelay = `${0.3 + i * 0.03}s`;
      el.appendChild(span);
    });
  }

  window.addEventListener('load', () => {
    scaleHeroCards();

    // Split hero title lines into characters
    const line1 = document.getElementById('hero-title-line1');
    const line2 = document.getElementById('hero-title-line2');
    if (line1) splitTextToChars(line1);
    if (line2) {
      // Line 2 starts after line 1 finishes — offset by line1 char count
      const line1Len = line1 ? line1.querySelectorAll('.hero-char').length : 0;
      const text = line2.textContent || '';
      line2.innerHTML = '';
      text.split('').forEach((char, i) => {
        const span = document.createElement('span');
        span.className = char === ' ' ? 'hero-char hero-char-space' : 'hero-char';
        span.textContent = char === ' ' ? '\u00A0' : char;
        span.style.animationDelay = `${0.3 + (line1Len + i) * 0.03}s`;
        line2.appendChild(span);
      });
    }

    // Calculate when title animation finishes, then fade in body + cards together
    const totalChars = (line1?.querySelectorAll('.hero-char').length || 0) + (line2?.querySelectorAll('.hero-char').length || 0);
    const fadeInDelay = 300 + totalChars * 30 + 200; // after last char + 200ms buffer

    setTimeout(() => {
      document.querySelectorAll('.hero-fade-group').forEach(el => {
        el.classList.add('hero-visible');
      });
    }, fadeInDelay);
  });

  // Scroll reveal — IntersectionObserver triggers .revealed class
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // Re-scale cards on resize/zoom
  window.addEventListener('resize', scaleHeroCards);

  // Scroll-based hero fade out / problem fade in
  // Uses getBoundingClientRect so it works correctly at any zoom level
  const heroBg = document.getElementById('hero-bg');
  const heroTextEl = document.getElementById('hero-text');
  const heroCardsEl = document.getElementById('hero-cards');
  const heroSection = document.getElementById('hero-section');
  const problemSection = document.getElementById('problem-section');

  function handleScroll() {
    if (!heroSection || !problemSection) return;

    const rect = heroSection.getBoundingClientRect();
    const viewH = window.innerHeight;

    const remaining = rect.bottom / viewH;

    if (remaining >= 0.7) {
      if (heroBg) heroBg.style.opacity = '1';
      if (heroTextEl) heroTextEl.style.opacity = '1';
      if (heroCardsEl) heroCardsEl.style.opacity = '1';
      if (problemSection) problemSection.style.opacity = '0';
    } else if (remaining <= 0.25) {
      if (heroBg) heroBg.style.opacity = '0';
      if (heroTextEl) heroTextEl.style.opacity = '0';
      if (heroCardsEl) heroCardsEl.style.opacity = '0';
      if (problemSection) problemSection.style.opacity = '1';
    } else {
      const progress = (0.7 - remaining) / (0.7 - 0.25);
      if (heroBg) heroBg.style.opacity = String(1 - progress);
      if (heroTextEl) heroTextEl.style.opacity = String(1 - progress);
      if (heroCardsEl) heroCardsEl.style.opacity = String(1 - progress);
      if (problemSection) problemSection.style.opacity = String(progress);
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Testimonial carousel — seamless infinite loop, auto-slides every 6s
  const slider = document.getElementById('testimonial-slider') as HTMLElement | null;
  const prevBtn = document.getElementById('testimonial-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('testimonial-next') as HTMLButtonElement | null;

  if (slider && prevBtn && nextBtn) {
    const originalCount = slider.children.length; // 7 real slides
    let currentIndex = 0;
    let autoSlideTimer: ReturnType<typeof setInterval>;
    let isTransitioning = false;

    function getVisibleCount() {
      const w = window.innerWidth;
      if (w < 600) return 1;
      if (w < 900) return 2;
      return 3;
    }

    // Clone enough slides at the end to fill one visible set for seamless wrapping
    function setupClones() {
      // Remove any existing clones
      slider!.querySelectorAll('[data-clone]').forEach(el => el.remove());
      const visible = getVisibleCount();
      for (let i = 0; i < visible; i++) {
        const clone = slider!.children[i].cloneNode(true) as HTMLElement;
        clone.setAttribute('data-clone', 'true');
        slider!.appendChild(clone);
      }
    }

    function slideWidthPercent() {
      return 100 / getVisibleCount();
    }

    function moveTo(index: number, animate = true) {
      if (!animate) {
        slider!.style.transition = 'none';
      } else {
        slider!.style.transition = 'transform 0.5s ease-in-out';
      }
      const offset = index * slideWidthPercent();
      slider!.style.transform = `translateX(-${offset}%)`;
      if (!animate) {
        // Force reflow so the non-animated jump applies instantly
        slider!.offsetHeight;
      }
    }

    function goNext() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex++;
      moveTo(currentIndex, true);
    }

    function goPrev() {
      if (isTransitioning) return;
      if (currentIndex <= 0) {
        // Jump to the end (no animation), then animate one step back
        currentIndex = originalCount;
        moveTo(currentIndex, false);
        requestAnimationFrame(() => {
          currentIndex--;
          isTransitioning = true;
          moveTo(currentIndex, true);
        });
        return;
      }
      isTransitioning = true;
      currentIndex--;
      moveTo(currentIndex, true);
    }

    // When transition ends, check if we've gone past the real slides and silently reset
    slider.addEventListener('transitionend', () => {
      isTransitioning = false;
      if (currentIndex >= originalCount) {
        currentIndex = 0;
        moveTo(0, false);
      }
    });

    function resetAutoSlide() {
      clearInterval(autoSlideTimer);
      autoSlideTimer = setInterval(goNext, 6000);
    }

    prevBtn.addEventListener('click', () => {
      goPrev();
      resetAutoSlide();
    });

    nextBtn.addEventListener('click', () => {
      goNext();
      resetAutoSlide();
    });

    // Pause auto-slide on hover
    const carouselSection = slider.closest('section');
    if (carouselSection) {
      carouselSection.addEventListener('mouseenter', () => clearInterval(autoSlideTimer));
      carouselSection.addEventListener('mouseleave', () => resetAutoSlide());
    }

    // Recalculate on resize
    window.addEventListener('resize', () => {
      setupClones();
      if (currentIndex > originalCount) currentIndex = 0;
      moveTo(currentIndex, false);
    });

    // Init
    setupClones();
    moveTo(0, false);
    autoSlideTimer = setInterval(goNext, 6000);
  }
</script>
