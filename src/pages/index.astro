---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- HERO WITH BACKGROUND IMAGE -->
  <section id="hero-section" class="relative -mt-18 md:-mt-20 hero-section-flex">
    <!-- Background Image -->
    <div id="hero-bg" class="absolute inset-0 z-0 transition-opacity duration-700" style="opacity: 1;">
      <img
        src="/images/sk1.jpg"
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-navy-900/60"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-16">
      <div class="hero-layout items-center">
        <!-- Left: Text -->
        <div id="hero-text">
          <h1 class="heading-serif text-4xl md:text-5xl lg:text-[3.8rem] text-linen mb-8 leading-[1.1]">
            <span id="hero-title-line1" class="hero-text-split inline-block overflow-hidden">More business.</span><br />
            <span id="hero-title-line2" class="hero-text-split text-neon italic inline-block overflow-hidden">Less busyness.</span>
          </h1>
          <!-- Desktop: hardcoded line breaks -->
          <div id="hero-body" class="hero-fade-group" style="opacity: 0; transform: translateY(20px);">
          <div id="hero-para-desktop" class="text-linen/80 text-[15px] leading-[1.7]" style="white-space: pre-line;">Most growing B2B teams aren't held back by ambition. They're held
back by friction. Wrong data feeding the wrong people. Outbound
that depends on discipline instead of systems. Manual work that
compounds quietly until someone burns out.

Skief Labs removes that friction. We build the data and outbound
systems that let your team focus on work that actually moves the
business forward.</div>
          <!-- Mobile: natural flow (shown only on very small screens) -->
          <div id="hero-para-mobile" class="text-linen/80 text-sm leading-[1.7]" style="display: none;">
            <p class="mb-4">Most growing B2B teams aren't held back by ambition. They're held back by friction. Wrong data feeding the wrong people. Outbound that depends on discipline instead of systems. Manual work that compounds quietly until someone burns out.</p>
            <p>Skief Labs removes that friction. We build the data and outbound systems that let your team focus on work that actually moves the business forward.</p>
          </div>
          <div class="mt-8 flex items-center gap-5 flex-wrap">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2 !text-[11px] !py-2.5 !px-5">
              Book a 30-minute discovery call
              <span class="btn-arrow">&rarr;</span>
            </a>
            <p class="text-linen/50 text-sm italic">No pitch. No obligation. Just clarity.</p>
          </div>
          </div><!-- end hero-body -->
        </div>

        <!-- Right: Visual Flow Cards with SVG arrows overlay -->
        <div id="hero-cards" class="hero-fade-group hero-cards-wrapper relative" style="opacity: 0; transform: translateY(20px);">

          <div class="hero-cards-inner relative" style="width: 550px; height: 490px;">
            <!-- Card 1: Daily Friction -->
            <div class="absolute bg-linen/95 backdrop-blur-sm rounded-lg px-6 py-4 text-center border border-navy-900/10 shadow-lg" style="width: 280px; height: 80px; top: 0; left: 30px; display: flex; flex-direction: column; justify-content: center;">
              <p class="font-serif italic text-navy-900 text-2xl tracking-wide"><s>Daily Friction</s></p>
              <p class="font-sans text-xs text-navy-900/50 mt-1 uppercase tracking-[0.08em] whitespace-nowrap">Fragile &middot; Human-Dependent</p>
            </div>

            <!-- Card 2: Built Systems -->
            <div class="absolute bg-navy-800/90 backdrop-blur-sm rounded-lg px-6 py-4 text-center border border-linen/10 shadow-lg" style="width: 280px; height: 80px; top: 195px; left: 250px; display: flex; flex-direction: column; justify-content: center;">
              <div class="absolute -top-3 left-4 bg-linen text-navy-900 text-[9px] font-semibold uppercase tracking-[0.1em] rounded text-center leading-none" style="padding: 4px 10px;">Transformation</div>
              <p class="font-serif text-linen text-2xl tracking-wide">Built Systems</p>
              <p class="font-sans text-xs text-linen/50 mt-1 uppercase tracking-[0.08em]">Data &middot; Outbound</p>
            </div>

            <!-- Card 3: Business Forward -->
            <div class="absolute bg-linen/95 backdrop-blur-sm rounded-lg px-6 py-4 text-center border border-navy-900/10 shadow-lg" style="width: 280px; height: 80px; top: 390px; left: 60px; display: flex; flex-direction: column; justify-content: center;">
              <p class="font-serif text-navy-900 text-2xl tracking-wide whitespace-nowrap">Business Forward</p>
              <p class="font-sans text-xs text-navy-900/50 mt-1 uppercase tracking-[0.08em]">Focused &middot; Scalable</p>
            </div>

            <!-- SVG Arrows connecting the cards -->
            <svg class="absolute inset-0 pointer-events-none" width="550" height="490" viewBox="0 0 550 490" fill="none" style="z-index: 1;">
              <line x1="190" y1="82" x2="190" y2="132" stroke="rgba(249,246,240,0.5)" stroke-width="1.5"/>
              <line x1="190" y1="132" x2="410" y2="132" stroke="rgba(249,246,240,0.5)" stroke-width="1.5"/>
              <line x1="410" y1="132" x2="410" y2="185" stroke="rgba(249,246,240,0.5)" stroke-width="1.5"/>
              <polygon points="405,183 410,195 415,183" fill="rgba(249,246,240,0.5)"/>

              <line x1="370" y1="277" x2="370" y2="330" stroke="rgba(249,246,240,0.5)" stroke-width="1.5"/>
              <line x1="370" y1="330" x2="200" y2="330" stroke="rgba(249,246,240,0.5)" stroke-width="1.5"/>
              <line x1="200" y1="330" x2="200" y2="380" stroke="rgba(249,246,240,0.5)" stroke-width="1.5"/>
              <polygon points="195,378 200,390 205,378" fill="rgba(249,246,240,0.5)"/>
            </svg>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section id="problem-section" class="bg-linen py-24 md:py-32 reveal">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <!-- Section Label -->
      <div class="inline-block border border-red-400 text-red-500 text-[10px] uppercase tracking-[0.2em] font-semibold px-4 py-1.5 rounded mb-8">
        The Problem
      </div>

      <h2 class="font-serif text-2xl md:text-3xl lg:text-[2.2rem] text-navy-900 mb-12 leading-[1.25] tracking-[-0.02em] max-w-3xl mx-auto">
        Your team is doing work the business<br />should be doing for them.
      </h2>

      <!-- Content Card -->
      <div class="bg-linen border-2 border-navy-900 rounded-lg p-8 md:p-12 text-left shadow-[6px_6px_0px_0px_rgba(0,18,51,1)]">
        <div class="space-y-5 text-navy-900/80 text-base md:text-lg leading-relaxed">
          <p>As B2B companies grow, something predictable happens.</p>
          <p>Tools multiply. Data fragments. Processes that worked at ten people start breaking at thirty. And somewhere along the way, your best people become the glue — manually researching, chasing, reconciling, compensating.</p>
          <p>It functions. Until it doesn't.</p>
          <p>The businesses we work with aren't failing. They're growing — and their systems haven't kept up. The cost is real: slower decisions, inconsistent outbound, senior time absorbed by work that shouldn't require senior people.</p>
          <p class="text-navy-900 font-bold">
            Adding more software doesn't fix this.<br />
            Adding more people only delays it.
          </p>
          <p>What changes things is replacing fragile, human-dependent effort with systems that work quietly in the background.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="bg-linen py-24 md:py-32 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="font-serif text-2xl md:text-3xl lg:text-[2.2rem] text-navy-900 mb-4 leading-[1.25] tracking-[-0.02em]">
          Two problems. Solved seriously.
        </h2>
        <p class="text-navy-900/70 text-base md:text-lg leading-relaxed" style="white-space: pre-line;">We don't do operations systems, general automation, or "digital transformation." We
work on two specific things with the depth that comes from choosing to go narrow
instead of wide.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10 reveal">
        <!-- Data Intelligence -->
        <div class="service-card bg-linen rounded-lg p-8 md:p-10 border-2">
          <div class="flex items-start justify-between mb-6">
            <div>
              <p class="subhead-condensed text-xs text-black/70 mb-2">Service One</p>
              <h3 class="font-serif text-2xl md:text-3xl text-black tracking-[-0.01em]">Data Intelligence</h3>
            </div>
            <!-- Database Icon -->
            <svg class="w-12 h-12 flex-shrink-0 ml-4" viewBox="0 0 48 48" fill="none" stroke="#001233" stroke-width="2">
              <ellipse cx="24" cy="10" rx="14" ry="5"/>
              <path d="M10 10v8c0 2.76 6.27 5 14 5s14-2.24 14-5v-8"/>
              <path d="M10 18v8c0 2.76 6.27 5 14 5s14-2.24 14-5v-8"/>
              <path d="M10 26v8c0 2.76 6.27 5 14 5s14-2.24 14-5v-8"/>
            </svg>
          </div>

          <p class="text-black/80 text-base leading-relaxed mb-8">
            The data your team needs — built, enriched, and delivered automatically. We replace manual research with automated pipelines that run continuously in the background.
          </p>

          <div class="space-y-6 mb-8">
            <div>
              <p class="font-bold text-black text-sm mb-1">Research & Scraping Pipelines</p>
              <p class="text-black/60 text-sm leading-relaxed">Contacts and companies collected automatically from sources that matter, continuously refreshed.</p>
            </div>
            <div>
              <p class="font-bold text-black text-sm mb-1">AI-Powered Enrichment</p>
              <p class="text-black/60 text-sm leading-relaxed">Layer context, qualify records, and score outputs so lists are clean and ready to act on.</p>
            </div>
            <div>
              <p class="font-bold text-black text-sm mb-1">Signal & Trigger Identification</p>
              <p class="text-black/60 text-sm leading-relaxed">Track hiring, funding, and tech changes automatically to surface buying signals.</p>
            </div>
          </div>

          <div class="flex items-center justify-between pt-6 border-t border-navy-900/20">
            <p class="text-black/60 text-xs italic">System builds from $5,000</p>
            <a href="/services#data-intelligence" class="font-bold text-black text-sm hover:text-blue-500 transition-colors duration-200 discuss-link">Learn more about Data Intelligence <span class="discuss-arrow">&rarr;</span></a>
          </div>
        </div>

        <!-- Sales Acceleration -->
        <div class="service-card bg-linen rounded-lg p-8 md:p-10 border-2">
          <div class="flex items-start justify-between mb-6">
            <div>
              <p class="subhead-condensed text-xs text-black/70 mb-2">Service Two</p>
              <h3 class="font-serif text-2xl md:text-3xl text-black tracking-[-0.01em]">Sales Acceleration</h3>
            </div>
            <!-- Rocket Icon -->
            <svg class="w-12 h-12 flex-shrink-0 ml-4" viewBox="0 0 24 24" fill="none" stroke="#001233" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
              <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
              <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
              <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
            </svg>
          </div>

          <p class="text-black/80 text-base leading-relaxed mb-8">
            More pipeline. Without more headcount. We fix the outbound system beneath the surface, then run it so your team focuses on conversations.
          </p>

          <div class="space-y-6 mb-8">
            <div>
              <p class="font-bold text-black text-sm mb-1">Outbound System Design</p>
              <p class="text-black/60 text-sm leading-relaxed">Full targeting logic, data sources, and sequence architecture designed before a single message is sent.</p>
            </div>
            <div>
              <p class="font-bold text-black text-sm mb-1">Done-For-You Operation</p>
              <p class="text-black/60 text-sm leading-relaxed">Research, enrichment, personalization, sequencing, and inbox management — handled by us.</p>
            </div>
            <div>
              <p class="font-bold text-black text-sm mb-1">Ongoing Optimization</p>
              <p class="text-black/60 text-sm leading-relaxed">We monitor performance, adjust messaging, and refresh targeting continuously.</p>
            </div>
          </div>

          <div class="flex items-center justify-between pt-6 border-t border-navy-900/20">
            <p class="text-black/60 text-xs italic">Pilots from $10,000</p>
            <a href="/services#sales-acceleration" class="font-bold text-black text-sm hover:text-blue-500 transition-colors duration-200 discuss-link">Learn more about Sales Acceleration <span class="discuss-arrow">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- A note on AI & Automation -->
      <div class="max-w-3xl mx-auto mt-16 bg-linen rounded-lg p-8 text-center border-2 border-navy-900 shadow-[6px_6px_0px_0px_#001233]">
        <p class="font-serif text-black text-lg mb-3"><span class="bg-neon px-2 py-0.5">A note on AI &amp; Automation</span></p>
        <p class="text-black/70 text-sm leading-relaxed" style="white-space: pre-line;">You'll notice we don't list AI and automation as a service. That's intentional. AI and automation
are how we build — not what we sell. The technology is never the point. The point is the outcome.</p>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-linen py-24 md:py-32 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <h2 class="font-serif text-2xl md:text-3xl lg:text-[2.2rem] text-navy-900 mb-6 leading-[1.25] tracking-[-0.02em]">
            This works best for a specific kind of company.
          </h2>
          <p class="text-navy-900/80 text-base md:text-lg leading-relaxed mb-8">
            B2B teams — typically 10 to 200 people — where:
          </p>
          <ul class="space-y-4 text-navy-900/80 text-base md:text-lg leading-relaxed mb-8 reveal reveal-children">
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 bg-neon rounded text-navy-900 text-xs flex-shrink-0 mt-0.5">&#10003;</span>
              <span>Growth has outpaced the systems underneath it</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 bg-neon rounded text-navy-900 text-xs flex-shrink-0 mt-0.5">&#10003;</span>
              <span>Manual effort increases faster than headcount</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 bg-neon rounded text-navy-900 text-xs flex-shrink-0 mt-0.5">&#10003;</span>
              <span>Data lives in spreadsheets, inboxes, and people's heads</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 bg-neon rounded text-navy-900 text-xs flex-shrink-0 mt-0.5">&#10003;</span>
              <span>Leadership wants outcomes, not another tool to manage</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 bg-neon rounded text-navy-900 text-xs flex-shrink-0 mt-0.5">&#10003;</span>
              <span>There is no internal automation or RevOps function — by choice or reality</span>
            </li>
          </ul>
          <p class="text-navy-900/60 text-base">
            If your people are the glue holding your data or outbound together, that's the pattern we fix.
          </p>
        </div>
        <!-- Image with neon accent shadow -->
        <div class="relative">
          <img src="/images/sk2.jpg" alt="Team collaboration" class="w-full rounded-lg object-cover shadow-[8px_8px_0px_0px_#CFFF15]" style="min-height: 500px;" />
        </div>
      </div>
    </div>
  </section>

  <!-- WHY SKIEF LABS -->
  <section class="bg-linen py-24 md:py-32 reveal">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16">
        <h2 class="font-serif text-2xl md:text-3xl lg:text-[2.2rem] text-navy-900 mb-6 leading-[1.25] tracking-[-0.02em]">
          Why choose <span class="italic">Skief Labs</span>?
        </h2>
        <p class="text-navy-900/70 text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-2">
          We are not an agency. Not a consultancy. Not a tool vendor.
        </p>
        <p class="text-navy-900/70 text-sm md:text-base leading-relaxed mx-auto" style="max-width: 46rem;"><span class="neon-underline">We're a small firm that builds systems — and operates them when that's what the work requires.</span></p>
      </div>

      <!-- Top row: 2 cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 reveal">
        <!-- Senior-Led -->
        <div class="why-card bg-linen rounded-lg p-8 md:p-10 border-2 text-center">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-linen mx-auto">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="#001233" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-navy-900 mb-3">Senior-Led</h3>
          <p class="text-navy-900/60 text-base leading-relaxed">
            Every engagement is led at a senior level.
          </p>
        </div>

        <!-- Fully Documented -->
        <div class="why-card bg-linen rounded-lg p-8 md:p-10 border-2 text-center">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-linen mx-auto">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="#001233" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h16z"/>
              <path d="m9 13 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-navy-900 mb-3">Fully Documented</h3>
          <p class="text-navy-900/60 text-base leading-relaxed">
            Everything is documented and handed over.
          </p>
        </div>
      </div>

      <!-- Bottom row: 2 cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mt-6 lg:mt-8 reveal">
        <!-- Deep Understanding -->
        <div class="why-card bg-linen rounded-lg p-8 md:p-10 border-2 text-center">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-linen mx-auto">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="#001233" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 18h8"/>
              <path d="M3 22h18"/>
              <path d="M14 22a7 7 0 1 0 0-14h-1"/>
              <path d="M9 14h2"/>
              <path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/>
              <path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-navy-900 mb-3">Deep Understanding</h3>
          <p class="text-navy-900/60 text-base leading-relaxed">
            Nothing is built before the problem is fully understood.
          </p>
        </div>

        <!-- Strategic Restraint -->
        <div class="why-card bg-linen rounded-lg p-8 md:p-10 border-2 text-center">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-linen mx-auto">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="#001233" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/>
              <path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/>
              <path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/>
              <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 13"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg text-navy-900 mb-3">Strategic Restraint</h3>
          <p class="text-navy-900/60 text-base leading-relaxed">
            We say no when something shouldn't be built. Restraint is part of the service.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF — carousel with arrows -->
  <section class="bg-linen py-20 md:py-28 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="font-serif text-2xl md:text-3xl lg:text-[2.2rem] text-navy-900 leading-[1.25] tracking-[-0.02em] mb-2">
            What our clients said
          </h2>
          <p class="text-navy-900/60 text-base md:text-lg leading-relaxed">Real feedback from the teams we've worked with.</p>
        </div>
        <div class="flex items-center gap-3">
          <button id="testimonial-prev" class="carousel-arrow" aria-label="Previous">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button id="testimonial-next" class="carousel-arrow" aria-label="Next">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <!-- Carousel -->
      <div class="relative">
        <!-- Cards container -->
        <div class="overflow-hidden">
          <div id="testimonial-slider" class="flex transition-transform duration-500 ease-in-out">
            <!-- Card 1 -->
            <div class="testimonial-slide">
              <div class="testimonial-card">
                <div class="text-navy-900 text-3xl font-serif leading-none mb-3">&ldquo;</div>
                <p class="text-navy-900/70 text-sm leading-relaxed mb-5">Skief Labs exceeded client's goal of 40 deals, achieving over 60. They efficiently streamlined workflow and collaboration, communicating daily. Constant support and understanding contribute to a successful ongoing partnership.</p>
                <div class="text-navy-900 text-3xl font-serif leading-none text-right mb-4">&rdquo;</div>
                <div class="border-t border-navy-900/10 pt-3">
                  <p class="font-bold text-navy-900 text-sm">Oscar Varas</p>
