---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Skief Labs',
  description = 'Skief Labs builds data intelligence and sales acceleration systems for B2B companies. Less friction. More pipeline. Systems that work.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-navy.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-linen.png" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      (function() {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        function updateFavicon(dark) {
          var href = dark ? '/favicon-linen.png' : '/favicon-navy.png';
          var links = document.querySelectorAll('link[rel="icon"]');
          links.forEach(function(link) { link.remove(); });
          var link = document.createElement('link');
          link.rel = 'icon';
          link.type = 'image/png';
          link.href = href + '?v=' + Date.now();
          document.head.appendChild(link);
        }
        updateFavicon(mq.matches);
        mq.addEventListener('change', function(e) { updateFavicon(e.matches); });
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Bodoni:wght@400;500;700&family=Barlow+Condensed:wght@300;400&family=Nunito:wght@300;400;600;700&family=Josefin+Sans:wght@300;400&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script is:inline>
      // Always scroll to top on page load / refresh
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);
    </script>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
    <ChatWidget />

    <!-- Scroll to top button -->
    <button id="scroll-top-btn" aria-label="Scroll to top" title="Back to top">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <style>
      #scroll-top-btn {
        position: fixed;
        bottom: 24px;
        right: 88px;
        z-index: 9997;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background-color: #001d52;
        color: #F9F6F0;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(0, 29, 82, 0.3);
        opacity: 0;
        transform: translateY(12px) scale(0.9);
        visibility: hidden;
        transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
        pointer-events: none;
      }
      #scroll-top-btn.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        visibility: visible;
        pointer-events: all;
      }
      #scroll-top-btn:hover {
        transform: scale(1.08);
        background-color: #001d52;
      }
    </style>

    <script>
      const scrollBtn = document.getElementById('scroll-top-btn');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollBtn?.classList.add('visible');
        } else {
          scrollBtn?.classList.remove('visible');
        }
      }, { passive: true });

      scrollBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
    <script>
      const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
      // If the URL has a hash (e.g. coming from the home page to #data-intelligence),
      // skip the entrance sequence entirely so content is visible immediately at the target.
      const hasHash = !!window.location.hash && window.location.hash.length > 1;
      if (!isHome) {
        // Page load animation for hero (skipped when navigating to a hash target)
        const main = document.querySelector('main');
        if (main && !hasHash) {
          main.classList.add('page-animate');
          requestAnimationFrame(() => {
            main.classList.add('page-loaded');
          });
        }
        // When arriving via hash, immediately reveal any page-load-only elements
        if (hasHash) {
          document.querySelectorAll('.page-hero-next').forEach((el) => {
            (el as HTMLElement).style.opacity = '1';
            (el as HTMLElement).style.transform = 'none';
          });
        }

        // Auto-apply reveal classes to all sections except hero
        const sections = document.querySelectorAll('main > section');
        sections.forEach((section, i) => {
          if (i === 0) return;
          section.classList.add('reveal');
        });

        // Scroll reveal observer — fires when an element's top crosses ~80px into the viewport,
        // so each section animates in as the user actually reaches it.
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0, rootMargin: '0px 0px -80px 0px' });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        // Only immediately reveal elements that are ALREADY inside the viewport on first paint
        // (prevents a flash of invisible content for sections already on screen, but leaves
        //  off-screen sections to animate in when the user scrolls to them).
        requestAnimationFrame(() => {
          document.querySelectorAll('.reveal:not(.revealed)').forEach((el) => {
            const rect = (el as HTMLElement).getBoundingClientRect();
            if (rect.top < window.innerHeight - 80 && rect.bottom > 0) {
              el.classList.add('revealed');
              revealObserver.unobserve(el);
            }
          });
        });
      }
    </script>
  </body>
</html>
