---
import { Image } from 'astro:assets';
import iconLogo from '../assets/Logos/Icon/Linen.png';

const servicesLinks = [
  { label: 'Data Intelligence', href: '/services#data-intelligence' },
  { label: 'Sales Acceleration', href: '/services#sales-acceleration' },
  { label: 'Use Cases', href: '/use-cases' },
];

const companyLinks = [
  { label: 'How We Work', href: '/how-we-work' },
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy' },
  { label: 'Terms of Service', href: '/terms-of-service' },
];
---

<footer class="relative overflow-hidden text-linen" style="background-color: #001D52;">
  <!-- Curved top edge (mirrors the hero's curved bottom edge). Linen fill peaks into the navy creating a dome in the middle. -->
  <div class="absolute top-0 left-0 right-0 z-10 pointer-events-none" style="line-height: 0;">
    <svg viewBox="0 0 1440 200" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full" style="height: 150px;">
      <path d="M0,200 Q720,0 1440,200 L1440,0 L0,0 Z" fill="#F9F6F0"/>
    </svg>
  </div>

  <!-- Tightened bottom spotlight glow — concentrated at dead-center, fades upward into the navy -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 65% 90% at 50% 100%, rgba(207,255,21,0.28) 0%, rgba(207,255,21,0.12) 25%, rgba(207,255,21,0.04) 50%, transparent 70%);"></div>

  <!-- Decorative rotating wireframe globe, peeking from the left edge (mirrors the hero's right-side globe) -->
  <canvas id="footer-globe" class="pointer-events-none absolute hidden lg:block" style="top: 540px; left: -280px; transform: translateY(-50%); width: 680px; height: 680px; z-index: 1; opacity: 0.95;"></canvas>

  <!-- Content -->
  <div class="relative z-20 max-w-6xl mx-auto px-6 lg:px-8 pt-32 md:pt-44 lg:pt-52 pb-10 md:pb-12">
    <!-- CTA Block -->
    <div class="text-center mb-14 md:mb-16 max-w-xl mx-auto">
      <h2 class="font-serif text-4xl md:text-5xl lg:text-[3.8rem] text-linen leading-[1.1] tracking-[-0.02em] mb-8" style="text-transform: none;">
        One entry point.<br />
        <span class="text-neon italic">Always the same.</span>
      </h2>
      <p class="text-linen/90 text-base md:text-lg leading-relaxed mb-10">
        30-minute discovery call. Not a pitch. Not a free audit. A focused conversation to understand where friction is concentrated.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-5">
        <a href="/contact" class="cta-book-btn btn-primary inline-flex items-center gap-2 text-xs !py-3.5 !px-6">
          Book a 30-minute discovery call
          <span class="btn-arrow">&rarr;</span>
        </a>
        <p class="text-linen/60 text-sm italic">No pitch. No obligation. Just clarity.</p>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-t border-linen/20 mb-10 md:mb-12" />

    <!-- Footer content grid -->
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 mb-10">
      <!-- Left: Logo, description, LinkedIn -->
      <div class="lg:flex-1">
        <div class="mb-4">
          <a href="/" aria-label="Skief Labs home" class="inline-block">
            <Image
              src={iconLogo}
              alt="Skief Labs"
              class="h-9 w-auto opacity-90 hover:opacity-100 transition-opacity duration-200"
              widths={[80, 120]}
            />
          </a>
        </div>
        <p class="text-linen/70 text-sm leading-relaxed mb-1 whitespace-nowrap">
          Data intelligence and sales acceleration systems for B2B companies.
        </p>
        <p class="text-linen/70 text-sm leading-relaxed mb-5 italic font-serif">
          More business. <span class="text-neon">Less busyness.</span>
        </p>
        <a
          href="https://www.linkedin.com/company/skief-labs"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center text-linen hover:text-linen/70 transition-colors duration-200"
          aria-label="LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- Services -->
      <div>
        <h4 class="subhead-condensed text-xs text-linen/50 mb-4">Services</h4>
        <ul class="space-y-2">
          {servicesLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-linen/85 hover:text-linen transition-colors duration-200 footer-nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="subhead-condensed text-xs text-linen/50 mb-4">Company</h4>
        <ul class="space-y-2">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-linen/85 hover:text-linen transition-colors duration-200 footer-nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="subhead-condensed text-xs text-linen/50 mb-4">Legal</h4>
        <ul class="space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-linen/85 hover:text-linen transition-colors duration-200 footer-nav-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Copyright centered -->
    <div class="pt-6 text-center">
      <p class="text-linen/50 text-xs">&copy; {new Date().getFullYear()} Skief Labs Corp. Miami, FL / St-Tropez, EU</p>
    </div>
  </div>
</footer>

<!-- Rotating footer globe (Three.js loaded in Layout head) -->
<script is:inline>
  (function initFooterGlobe() {
    function start() {
      const canvas = document.getElementById('footer-globe');
      if (!canvas || typeof window.THREE === 'undefined') return;

      const THREE = window.THREE;

      const getSize = () => ({
        w: canvas.clientWidth || 680,
        h: canvas.clientHeight || 680
      });

      let { w, h } = getSize();

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, w / h, 0.1, 100);
      camera.position.z = 6;

      const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(w, h, false);

      const group = new THREE.Group();

      const wireGeo = new THREE.IcosahedronGeometry(1.6, 1);
      const wireMat = new THREE.MeshBasicMaterial({
        color: 0xF9F6F0,
        wireframe: true,
        transparent: true,
        opacity: 0.55
      });
      group.add(new THREE.Mesh(wireGeo, wireMat));

      const dotsGeo = new THREE.IcosahedronGeometry(1.9, 3);
      const dotsMat = new THREE.PointsMaterial({
        size: 0.035,
        color: 0xF9F6F0,
        transparent: true,
        opacity: 0.9
      });
      group.add(new THREE.Points(dotsGeo, dotsMat));

      const neonGeo = new THREE.IcosahedronGeometry(2.3, 1);
      const neonMat = new THREE.PointsMaterial({
        size: 0.08,
        color: 0xCFFF15,
        transparent: true,
        opacity: 0.95
      });
      const neonDots = new THREE.Points(neonGeo, neonMat);
      group.add(neonDots);

      scene.add(group);

      function animate() {
        requestAnimationFrame(animate);
        // Rotate opposite direction from hero so they feel like complementary bookends
        group.rotation.y -= 0.0012;
        group.rotation.x -= 0.0003;
        neonDots.rotation.y += 0.0008;
        neonDots.rotation.x -= 0.0005;
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', () => {
        const size = getSize();
        camera.aspect = size.w / size.h;
        camera.updateProjectionMatrix();
        renderer.setSize(size.w, size.h, false);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', start);
    } else {
      start();
    }
  })();
</script>

<script>
  document.querySelectorAll('.footer-nav-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      const anchor = e.currentTarget as HTMLAnchorElement;
      const url = new URL(anchor.href);
      const hash = url.hash;
      const targetPath = url.pathname.replace(/\/$/, '');
      const currentPath = window.location.pathname.replace(/\/$/, '');

      // If link has a hash and we're already on that page, smooth scroll
      if (hash && targetPath === currentPath) {
        e.preventDefault();
        const target = document.querySelector(hash);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', hash);
        }
      }
      // If link points to current page without hash, scroll to top
      else if (!hash && targetPath === currentPath) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  });
</script>
