---
import { Image } from 'astro:assets';
import iconLogo from '../assets/Logos/Icon/Linen.png';

const servicesLinks = [
  { label: 'Data Intelligence', href: '/services' },
  { label: 'Sales Acceleration', href: '/services' },
  { label: 'Use Cases', href: '/use-cases' },
];

const companyLinks = [
  { label: 'How We Work', href: '/how-we-work' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy' },
  { label: 'Terms of Service', href: '/terms-of-service' },
];
---

<footer class="bg-navy-900 text-linen border-t border-linen/5 py-12">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-16 mb-12">
      <!-- Left: Logo, description, LinkedIn -->
      <div class="lg:w-auto">
        <div class="mb-4">
          <Image
            src={iconLogo}
            alt="Skief Labs"
            class="h-10 w-auto opacity-70"
            widths={[80, 120]}
          />
        </div>
        <p class="text-linen/50 text-sm leading-relaxed max-w-md mb-2">
          Data intelligence and sales acceleration systems for B2B companies.
        </p>
        <p class="text-linen/50 text-sm leading-relaxed mb-4 max-w-md italic font-serif">
          More business. <span class="text-neon">Less busyness.</span>
        </p>
        <a
          href="https://www.linkedin.com/company/skief-labs"
          target="_blank"
          rel="noopener noreferrer"
          class="text-linen/40 hover:text-linen transition-colors duration-200 inline-block"
          aria-label="LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- Services -->
      <div class="lg:w-auto">
        <h4 class="subhead-condensed text-xs text-linen/40 mb-4">Services</h4>
        <ul class="space-y-2">
          {servicesLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-linen/60 hover:text-linen transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="lg:w-auto">
        <h4 class="subhead-condensed text-xs text-linen/40 mb-4">Company</h4>
        <ul class="space-y-2">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-linen/60 hover:text-linen transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="lg:w-auto">
        <h4 class="subhead-condensed text-xs text-linen/40 mb-4">Legal</h4>
        <ul class="space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-linen/60 hover:text-linen transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 border-t border-linen/10 gap-4">
      <p class="text-linen/30 text-xs">&copy; {new Date().getFullYear()} Skief Labs Corp.</p>
      <p class="text-linen/30 text-xs">Miami, FL / St-Tropez, EU</p>
    </div>
  </div>
</footer>
